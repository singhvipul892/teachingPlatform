# Production environment variables — copy to .env and fill in all CHANGE_ME values.
# NEVER commit .env to git.

# --- PostgreSQL ---
POSTGRES_DB=teacher_videos
POSTGRES_USER=teacher
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# --- Spring datasource (must match PostgreSQL values above) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/teacher_videos
SPRING_DATASOURCE_USERNAME=teacher
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_strong_db_password
SPRING_PROFILES_ACTIVE=prod

# --- JWT ---
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_EXPIRATION_MS=604800000

# --- AWS S3 ---
APP_STORAGE_S3_REGION=ap-south-1
APP_STORAGE_S3_BUCKET=teacherplatform.503561455300
APP_STORAGE_S3_PRESIGN_EXPIRY_MINUTES=10

# --- Razorpay (use LIVE keys in production) ---
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=CHANGE_ME_razorpay_live_secret

# --- Nginx ---
# Use nginx.no-ssl.conf on first deploy (before certs exist).
# Switch to nginx.conf after obtaining SSL certificates.
NGINX_CONF=nginx.conf

# --- SMS ---
SMS_MOCK=false
